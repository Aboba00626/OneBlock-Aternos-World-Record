# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: ALPHA
# ====================================================================================================

options:
    p: §8[§6InfinityOB§8] §7
    line: §8§m------------------------------------------------
    # Лимиты фаз
    ph1: 50
    ph2: 250
    ph3: 750
    ph4: 2000
    ph5: 5000
    ph6: 10000
    ph7: 20000

# ----------------------------------------------------------------------------------------------------
# 1. СИСТЕМА ИНИЦИАЛИЗАЦИИ
# ----------------------------------------------------------------------------------------------------

on load:
    set {ob.system.active} to true
    register_recipes()
    send "{@p} §aЯдро Alpha загружено. Рецепты зарегистрированы." to console

function register_recipes():
    # Бур 1 уровня
    set {_i} to diamond pickaxe named "§6§lБУР: УРОВЕНЬ I" with lore "§7Скорость: §e|||||", "§7Тип: §6Инструмент"
    enchant {_i} with efficiency 7
    register new shaped recipe for {_i} using diamond block, iron block, diamond block, air, stick, air, air, stick, air
    
    # Меч Правосудия
    set {_s} to netherite sword named "§4§lМЕЧ ПРАВОСУДИЯ" with lore "§7Урон по боссам: §c+25%%"
    enchant {_s} with sharpness 6
    register new shaped recipe for {_s} using netherite ingot, diamond block, netherite ingot, air, stick, air, air, stick, air

# ----------------------------------------------------------------------------------------------------
# 2. ГЛАВНЫЙ КОМАНДНЫЙ ЦЕНТР
# ----------------------------------------------------------------------------------------------------

command /ob [<text>] [<text>]:
    permission: op
    trigger:
        if arg 1 is not set:
            send "{@line}"
            send "           §6§lONEBLOCK INFINITY"
            send "§e/ob set §7- Установить точку генерации"
            send "§e/ob stats §7- Посмотреть свою статистику"
            send "§e/ob shop §7- Открыть магазин за блоки"
            send "§e/ob phase §7- Информация о текущей фазе"
            send "§e/ob fix §7- Принудительный спавн блока"
            send "{@line}"
            stop

        if arg 1 is "set":
            set {ob.loc} to location of target block
            set {ob.broken} to 0
            set {ob.level} to 1
            set {ob.levelname} to "§a§lРАВНИНА"
            set block at {ob.loc} to grass block
            create_bossbar(player)
            send "{@p} §aТочка установлена! Мир начал развитие."

        if arg 1 is "fix":
            set block at {ob.loc} to grass block
            delete {ob.cooldown}
            send "{@p} §bБлок восстановлен."

        if arg 1 is "phase":
            send "{@p} §fТекущая фаза: %{ob.levelname}%"
            send "{@p} §fВсего сломано: §e%{ob.broken}%"

# ----------------------------------------------------------------------------------------------------
# 3. ДВИЖОК ГЕНЕРАЦИИ (BREAK ENGINE)
# ----------------------------------------------------------------------------------------------------

on break:
    if location of event-block is {ob.loc}:
        cancel event
        
        # Защита от сверхбыстрой добычи (анти-лаг)
        if {ob.cooldown} is true:
            stop
        set {ob.cooldown} to true
        
        # 1. Обработка ресурсов (Авто-плавка)
        handle_resources(player, event-block)
        
        # 2. Прогресс
        add 1 to {ob.broken}
        add 1 to {ob.broken.%player%}
        
        # 3. Проверка фаз
        check_phases(player)
        
        # 4. Шансы на События
        if chance of 8%:
            trigger_event(player)

        # 5. Моментальное восстановление
        wait 1 tick
        generate_block()
        
        # Визуальные эффекты
        play sound "block.amethyst_block.hit" with volume 0.2 at {ob.loc}
        play flame at {ob.loc}
        
        delete {ob.cooldown}

# ----------------------------------------------------------------------------------------------------
# 4. ФУНКЦИИ ГЕНЕРАЦИИ (10 УРОВНЕЙ)
# ----------------------------------------------------------------------------------------------------

function generate_block():
    set {_lv} to {ob.level}
    
    if {_lv} is 1:
        set {_b::*} to grass block, dirt, oak log, oak leaves, clay, melon, pumpkin
    else if {_lv} is 2:
        set {_b::*} to stone, cobblestone, coal ore, iron ore, andesite, diorite, granite
    else if {_lv} is 3:
        set {_b::*} to deepslate, iron ore, copper ore, raw iron block, gravel, moss block, tuff
    else if {_lv} is 4:
        set {_b::*} to sand, gravel, prismarine, sea lantern, coral block, wet sponge, blue ice
    else if {_lv} is 5:
        set {_b::*} to netherrack, soul sand, magma block, nether gold ore, glowstone, basalt
    else if {_lv} is 6:
        set {_b::*} to end stone, obsidian, crying obsidian, diamond ore, emerald ore, gold block
    else:
        set {_b::*} to bedrock, diamond block, emerald block, netherite block, beacon, gilded blackstone
        
    set block at {ob.loc} to random element of {_b::*}

# ----------------------------------------------------------------------------------------------------
# 5. СИСТЕМА ФАЗ И BOSSBAR
# ----------------------------------------------------------------------------------------------------

function create_bossbar(p: player):
    remove bossbar "ob_bar"
    create bossbar title "§fЗагрузка..." id "ob_bar" value 100 for all players
    set bossbar "ob_bar" color green

function check_phases(p: player):
    if {ob.broken} is {@ph1}:
        update_phase("§7§lПЕЩЕРА", gray, 2)
    else if {ob.broken} is {@ph2}:
        update_phase("§8§lГЛУБИНЫ", black, 3)
    else if {ob.broken} is {@ph3}:
        update_phase("§b§lОКЕАН", blue, 4)
    else if {ob.broken} is {@ph4}:
        update_phase("§c§lНЕЗЕР", red, 5)
    else if {ob.broken} is {@ph5}:
        update_phase("§d§lЭНД", purple, 6)
    
    # Обновление текста в BossBar
    set bossbar "ob_bar" title to "§fФаза: %{ob.levelname}% §8| §eБлоков: %{ob.broken}%"
    set bossbar "ob_bar" value to ({ob.broken} / 5000) * 100

function update_phase(name: text, color: color, lv: number):
    set {ob.levelname} to {_name}
    set {ob.level} to {_lv}
    set bossbar "ob_bar" color {_color}
    broadcast "{@p} §lМИР ЭВОЛЮЦИОНИРОВАЛ! §fНовая фаза: %{_name}%"
    play sound "ui.toast.challenge_complete" to all players
    play lightning effect at {ob.loc}

# ----------------------------------------------------------------------------------------------------
# 6. АВТО-ПЛАВКА И СБОР
# ----------------------------------------------------------------------------------------------------

function handle_resources(p: player, b: block):
    set {_drops::*} to drops of {_b} using tool of {_p}
    loop {_drops::*}:
        set {_item} to loop-value
        if {_item} is raw iron:
            give 1 iron ingot to {_p}
        else if {_item} is raw gold:
            give 1 gold ingot to {_p}
        else if {_item} is raw copper:
            give 1 copper ingot to {_p}
        else:
            give {_item} to {_p}

# ----------------------------------------------------------------------------------------------------
# 7. ЗАЩИТА ОТ ПУСТОТЫ
# ----------------------------------------------------------------------------------------------------

every 2 seconds:
    if {ob.loc} is set:
        if block at {ob.loc} is air:
            generate_block()
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: BETA
# ====================================================================================================
# В этой части: Боссы, Магия, Кланы и Глобальная Экономика.

# ----------------------------------------------------------------------------------------------------
# 8. СИСТЕМА СПОСОБНОСТЕЙ (SKILLS)
# ----------------------------------------------------------------------------------------------------

command /skills:
    trigger:
        send "{@line}"
        send "           §d§lМАГИЧЕСКИЕ СПОСОБНОСТИ"
        send "§e[1] §fСупер-Прыжок §7(Цена: 500 блоков) §8- /skill buy 1"
        send "§e[2] §fЯростный Шахтер §7(Цена: 1000 блоков) §8- /skill buy 2"
        send "§e[3] §fВзрыв Бездны §7(Цена: 5000 блоков) §8- /skill buy 3"
        send "{@line}"

command /skill <text> <number>:
    trigger:
        if arg 1 is "buy":
            if arg 2 is 1:
                if {ob.broken.%player%} >= 500:
                    remove 500 from {ob.broken.%player%}
                    set {ob.skill.jump.%player%} to true
                    send "{@p} §aСпособность куплена! Нажми Shift, чтобы прыгнуть."
                else:
                    send "{@err} Недостаточно блоков!"
            if arg 2 is 2:
                if {ob.broken.%player%} >= 1000:
                    remove 1000 from {ob.broken.%player%}
                    apply haste 3 to player for 10 minutes
                    send "{@p} §aАктивировано ускорение копания на 10 минут!"
            if arg 2 is 3:
                if {ob.broken.%player%} >= 5000:
                    remove 5000 from {ob.broken.%player%}
                    execute_void_blast(player)

on sneak:
    if {ob.skill.jump.%player%} is true:
        if player is on ground:
            push player upwards with force 1.2
            play sound "entity.bat.takeoff" to player
            play cloud at player

function execute_void_blast(p: player):
    loop all entities in radius 10 of {_p}:
        if loop-entity is not {_p}:
            make {_p} damage loop-entity by 20
            play huge explosion at loop-entity

# ----------------------------------------------------------------------------------------------------
# 9. СИСТЕМА КЛАНОВ (CLANS)
# ----------------------------------------------------------------------------------------------------

command /clan [<text>] [<text>]:
    trigger:
        if arg 1 is "create":
            if {ob.clan.%player%} is set:
                send "{@err} Ты уже в клане!"
                stop
            set {ob.clan.%player%} to arg 2
            add player to {ob.clan.members.%arg 2%::*}
            send "{@p} §aКлан §l%arg 2% §aсоздан!"
        
        if arg 1 is "invite":
            set {_p} to arg 2 parsed as player
            if {ob.clan.%player%} is not set:
                send "{@err} Сначала создай клан!"
                stop
            set {ob.clan.invite.%{_p}%} to {ob.clan.%player%}
            send "{@p} §fИгрок %player% пригласил тебя в клан %{ob.clan.%player%}%! §e/clan join" to {_p}

        if arg 1 is "join":
            if {ob.clan.invite.%player%} is set:
                set {ob.clan.%player%} to {ob.clan.invite.%player%}
                add player to {ob.clan.members.%{ob.clan.%player%}%::*}
                send "{@p} §aТы вступил в клан %{ob.clan.%player%}%!"
                delete {ob.clan.invite.%player%}

# ----------------------------------------------------------------------------------------------------
# 10. РЕЙДОВЫЕ БОССЫ (BOSS RAIDS)
# ----------------------------------------------------------------------------------------------------

function trigger_event(p: player):
    set {_r} to random integer between 1 and 100
    if {_r} :
    trigger:
        if arg 1 is 1:
            if {ob.broken.%player%} >= 10000:
                remove 10000 from {ob.broken.%player%}
                give 1 diamond pickaxe of efficiency 15 named "§b§lБЕРСЕРК" to player
            else:
                send "{@err} Мало блоков!"
        if arg 1 is 4:
            if {ob.broken.%player%} >= 1000:
                remove 1000 from {ob.broken.%player%}
                set {_reward} to random integer between 1 and 5
                if {_reward} is 1:
                    give 5 diamond block to player
                if {_reward} is 2:
                    give 1 netherite ingot to player
                send "{@p} §aТы открыл кейс и получил награду!"

# ----------------------------------------------------------------------------------------------------
# 12. ТАБЛИЦА ЛИДЕРОВ (TOP 10)
# ----------------------------------------------------------------------------------------------------

command /obtop:
    trigger:
        send "{@line}"
        send "           §e§lТОП-10 КОПАТЕЛЕЙ"
        # Логика сортировки (упрощенно)
        set {_count} to 1
        loop {ob.broken.*}:
            send "§7%{_count}%. §f%loop-index% §8- §e%loop-value% бл."
            add 1 to {_count}
            if {_count} > 10:
                stop
        send "{@line}"

# ----------------------------------------------------------------------------------------------------
# 13. СИСТЕМА УВЕДОМЛЕНИЙ (ACTIONBAR)
# ----------------------------------------------------------------------------------------------------

on break:
    if location of event-block is {ob.loc}:
        send action bar "§6Блоков сломано: §e%{ob.broken.%player%}% §7| §bФаза: %{ob.level}%" to player

# ====================================================================================================
# КОНЕЦ МОДУЛЯ БЕТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~750-800
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: GAMMA
# ====================================================================================================
# В этой части: Авто-Острова, Питомцы, Ежедневные Награды и Система Достижений.

# ----------------------------------------------------------------------------------------------------
# 14. СИСТЕМА ЛИЧНЫХ ОСТРОВОВ (AUTO-ISLAND)
# ----------------------------------------------------------------------------------------------------

command /is create:
    trigger:
        if {ob.has_island.%player%} is set:
            send "{@err} У тебя уже есть остров! §e/is home"
            stop
        
        # Генерация платформы 3x3 под ногами
        set {_loc} to location of player
        set {ob.island_loc.%player%} to {_loc}
        set {ob.has_island.%player%} to true
        
        loop blocks in radius 2 around {_loc}:
            if y-coordinate of loop-block is y-coordinate of {_loc} - 1:
                set loop-block to grass block
        
        send "{@p} §aОстров создан! Мы построили небольшую платформу под тобой."
        play sound "block.grass.place" to player

command /is home:
    trigger:
        if {ob.has_island.%player%} is set:
            teleport player to {ob.island_loc.%player%}
            send "{@p} §aТы телепортирован домой!"
        else:
            send "{@err} Сначала создай остров: §e/is create"

# ----------------------------------------------------------------------------------------------------
# 15. СИСТЕМА ПИТОМЦЕВ (PETS SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /pets:
    trigger:
        send "{@line}"
        send "           §6§lТВОИ ПИТОМЦЫ"
        send "§e §fСборщик §7(5000 бл.) §8- Собирает ресурсы за тебя"
        send "§e §fЗащитник §7(7000 бл.) §8- Бьет мобов вокруг"
        send "§7Используй: §e/pet buy <тип>"
        send "{@line}"

command /pet <text> <text>:
    trigger:
        if arg 1 is "buy":
            if arg 2 is "collector":
                if {ob.broken.%player%} >= 5000:
                    remove 5000 from {ob.broken.%player%}
                    spawn_pet(player, "COLLECTOR")
                else:
                    send "{@err} Недостаточно блоков!"
            if arg 2 is "guard":
                if {ob.broken.%player%} >= 7000:
                    remove 7000 from {ob.broken.%player%}
                    spawn_pet(player, "GUARD")

function spawn_pet(p: player, type: text):
    if {ob.active_pet.%{_p}%} is set:
        delete {ob.active_pet.%{_p}%}
    
    if {_type} is "COLLECTOR":
        spawn chicken at {_p}
        set {_pet} to last spawned entity
        set name of {_pet} to "§a§lСборщик %{_p}%"
    else:
        spawn wolf at {_p}
        set {_pet} to last spawned entity
        set name of {_pet} to "§c§lЗащитник %{_p}%"
        tame {_pet} to {_p}
    
    set {ob.active_pet.%{_p}%} to {_pet}
    send "{@p} §aПитомец призван!" to {_p}

# Логика работы Сборщика (автоматически кладет ресурсы в сундук рядом)
on break:
    if {ob.active_pet.%player%} is set:
        if name of {ob.active_pet.%player%} contains "Сборщик":
            # 10% шанс, что питомец удвоит дроп
            if chance of 10%:
                set {_items::*} to drops of event-block using player's tool
                loop {_items::*}:
                    give loop-value to player
                send "§7[§a!§7] §fПитомец удвоил дроп!" to player

# ----------------------------------------------------------------------------------------------------
# 16. ЕЖЕДНЕВНЫЕ НАГРАДЫ (DAILY REWARDS)
# ----------------------------------------------------------------------------------------------------

command /daily:
    trigger:
        set {_waited} to difference between {ob.daily.%player%} and now
        if {_waited} is less than 24 hours:
            send "{@err} Приходи через %difference between 24 hours and {_waited}%"
            stop
        
        set {ob.daily.%player%} to now
        set {_r} to random integer between 500 and 2000
        add {_r} to {ob.broken.%player%}
        give 1 diamond to player
        send "{@p} §aЕжедневная награда получена! §e+%{_r}% блоков и 1 Алмаз."
        play sound "entity.experience_orb.pickup" to player

# ----------------------------------------------------------------------------------------------------
# 17. СИСТЕМА ДОСТИЖЕНИЙ (ACHIEVEMENTS)
# ----------------------------------------------------------------------------------------------------

on break:
    if location of event-block is {ob.loc}:
        # Достижение: Первый Камень
        if {ob.broken.%player%} is 100:
            unlock_advancement(player, "Первые Шаги", "Сломано 100 блоков")
        
        # Достижение: Копатель
        if {ob.broken.%player%} is 1000:
            unlock_advancement(player, "Копатель", "Сломано 1000 блоков")
            give 1 netherite scrap to player

function unlock_advancement(p: player, name: text, desc: text):
    send " " to {_p}
    send "§e§l⭐ ДОСТИЖЕНИЕ ПОЛУЧЕНО! ⭐" to {_p}
    send "§fНазвание: §6%{_name}%" to {_p}
    send "§7%{_desc}%" to {_p}
    send " " to {_p}
    play sound "ui.toast.challenge_complete" to {_p}

# ----------------------------------------------------------------------------------------------------
# 18. ГЛОБАЛЬНАЯ ЧИСТКА МОБОВ (ANTI-LAG)
# ----------------------------------------------------------------------------------------------------

every 15 minutes:
    broadcast "{@p} §7Очистка бесхозных мобов через 10 секунд..."
    wait 10 seconds
    loop all entities:
        if loop-entity is a zombie or skeleton or spider or creeper:
            if loop-entity's display name is not set: # Не удалять боссов
                delete loop-entity
    broadcast "{@p} §aМир очищен!"

# ====================================================================================================
# ФИНАЛ. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~1000+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: DELTA
# ====================================================================================================
# В этой части: Генераторы ресурсов, Система Навыков, Глобальные События и Банк.

# ----------------------------------------------------------------------------------------------------
# 19. СИСТЕМА ПАССИВНЫХ ГЕНЕРАТОРОВ (GENERATORS)
# ----------------------------------------------------------------------------------------------------

command /gen [<text>]:
    trigger:
        if arg 1 is "buy":
            open_gen_shop(player)
        else:
            send "{@line}"
            send "           §6§lТВОИ ГЕНЕРАТОРЫ"
            send "§fУровень генерации: §e%{ob.gen.level.%player%}%"
            send "§fДоход в минуту: §a%({ob.gen.level.%player%} * 10)% блоков"
            send "§7Используй: §e/gen buy §7для улучшения"
            send "{@line}"

function open_gen_shop(p: player):
    send "{@line}" to {_p}
    send "§6§lУЛУЧШЕНИЕ ГЕНЕРАЦИИ" to {_p}
    set {_price} to ({ob.gen.level.%{_p}%} + 1) * 2000
    send "<tooltip:§7Нажми для улучшения><run command:/genupgrade>§7[§fПовысить уровень до %{ob.gen.level.%{_p}%} + 1% §e(%{_price}% бл.)§7]" to {_p}
    send "{@line}" to {_p}

command /genupgrade:
    trigger:
        set {_price} to ({ob.gen.level.%player%} + 1) * 2000
        if {ob.broken.%player%} >= {_price}:
            remove {_price} from {ob.broken.%player%}
            add 1 to {ob.gen.level.%player%}
            send "{@p} §aГенератор улучшен! Теперь ты получаешь больше пассивного дохода."
            play sound "block.iron_door.open" to player
        else:
            send "{@err} Недостаточно блоков!"

# Цикл пассивного дохода (каждую минуту)
every 1 minute:
    loop all players:
        if {ob.gen.level.%loop-player%} > 0:
            set {_income} to {ob.gen.level.%loop-player%} * 10
            add {_income} to {ob.broken.%loop-player%}
            send action bar "§6§l+§e%{_income}% §fблоков (Доход от генератора)" to loop-player

# ----------------------------------------------------------------------------------------------------
# 20. ДЕРЕВО НАВЫКОВ ИГРОКА (SKILL TREE)
# ----------------------------------------------------------------------------------------------------

command /talents:
    trigger:
        send "§6§l─── ТВОИ ТАЛАНТЫ ───"
        send "§f1. §6Удача §7[%{ob.talent.luck.%player%}%/5] §8- Больше ресурсов"
        send "§f2. §cСила §7[%{ob.talent.strength.%player%}%/5] §8- Урон по боссам"
        send "§f3. §bСкорость §7[%{ob.talent.speed.%player%}%/5] §8- Бег"
        send "§7Прокачка: §e/talent upgrade <1-3> §7(Цена: 5000)"
        send "§6§l──────────────────"

command /talent <text> <number>:
    trigger:
        if arg 1 is "upgrade":
            if {ob.broken.%player%} >= 5000:
                if arg 2 is 1:
                    if {ob.talent.luck.%player%} < 5:
                        add 1 to {ob.talent.luck.%player%}
                        remove 5000 from {ob.broken.%player%}
                        send "{@p} §aУдача повышена!"
                if arg 2 is 2:
                    if {ob.talent.strength.%player%} < 5:
                        add 1 to {ob.talent.strength.%player%}
                        remove 5000 from {ob.broken.%player%}
                        send "{@p} §aСила повышена!"
            else:
                send "{@err} Мало блоков!"

# Применение таланта Удача (влияет на дроп)
on break:
    if location of event-block is {ob.loc}:
        if {ob.talent.luck.%player%} > 0:
            if chance of ({ob.talent.luck.%player%} * 5)%:
                give event-block to player
                send "§7[§6Удача§7] §fВыпал двойной дроп!" to player

# ----------------------------------------------------------------------------------------------------
# 21. ГЛОБАЛЬНЫЕ ИВЕНТЫ (GLOBAL EVENTS)
# ----------------------------------------------------------------------------------------------------

every 30 minutes:
    set {ob.event.active} to true
    broadcast "{@p} §6§lГЛОБАЛЬНОЕ СОБЫТИЕ: §e§lЧАС УДАЧИ!"
    broadcast "{@p} §fВ течение 5 минут за каждый блок дают §6x2 очков§f!"
    
    wait 5 minutes
    set {ob.event.active} to false
    broadcast "{@p} §cСобытие 'Час удачи' закончилось."

# Модификация начисления очков во время ивента
on break:
    if location of event-block is {ob.loc}:
        if {ob.event.active} is true:
            add 1 to {ob.broken.%player%} # Дополнительное очко

# ----------------------------------------------------------------------------------------------------
# 22. БАНКОВСКАЯ СИСТЕМА (BANK)
# ----------------------------------------------------------------------------------------------------

command /bank [<text>] [<number>]:
    trigger:
        if arg 1 is "deposit":
            if {ob.broken.%player%} >= arg 2:
                remove arg 2 from {ob.broken.%player%}
                add arg 2 to {ob.bank.%player%}
                send "{@p} §aВы положили §e%arg 2% §aблоков в банк."
            else:
                send "{@err} Недостаточно блоков в инвентаре!"
        
        if arg 1 is "withdraw":
            if {ob.bank.%player%} >= arg 2:
                remove arg 2 from {ob.bank.%player%}
                add arg 2 to {ob.broken.%player%}
                send "{@p} §aВы сняли §e%arg 2% §aблоков из банка."
            else:
                send "{@err} В банке нет такой суммы!"
        
        if arg 1 is not set:
            send "{@line}"
            send "           §2§lБАНК ОДНОГО БЛОКА"
            send "§fНа счету: §e%{ob.bank.%player%}% блоков"
            send "§7Команды: §e/bank deposit <кол-во> §7| §e/bank withdraw <кол-во>"
            send "{@line}"

# ----------------------------------------------------------------------------------------------------
# 23. СИСТЕМА УРОВНЕЙ БЛОКА (HOLOGRAM INFOS)
# ----------------------------------------------------------------------------------------------------

every 2 seconds:
    if {ob.loc} is set:
        # Если есть плагин HolographicDisplays, тут можно вызвать команду обновления.
        # Если нет, просто выводим частицы уровня над блоком.
        if {ob.level} is 1:
            play green dust at {ob.loc}
        else if {ob.level} is 2:
            play gray dust at {ob.loc}

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ДЕЛЬТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~1300+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: EPSILON
# ====================================================================================================
# В этой части: ПВП-награды, Косметика (Ауры), Артефакты и Система Престижа.

# ----------------------------------------------------------------------------------------------------
# 24. СИСТЕМА ПРЕСТИЖА (PRESTIGE SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /prestige:
    trigger:
        if {ob.broken.%player%} >= 100000:
            open_prestige_menu(player)
        else:
            send "{@err} Для Престижа нужно сломать 100.000 блоков! Тебе не хватает: §e%100000 - {ob.broken.%player%}%"

function open_prestige_menu(p: player):
    send "{@line}" to {_p}
    send "§d§lСИСТЕМА ПРЕСТИЖА" to {_p}
    send "§7Сбрось свой прогресс (блоки и фазу), чтобы получить постоянный бонус §6+50%% к очкам§7."
    send "<tooltip:§cВНИМАНИЕ: Это сбросит блоки!><run command:/prestigeconfirm>§7[§d§lСОВЕРШИТЬ ПЕРЕРОЖДЕНИЕ§7]" to {_p}
    send "{@line}" to {_p}

command /prestigeconfirm:
    trigger:
        if {ob.broken.%player%} >= 100000:
            set {ob.broken.%player%} to 0
            add 1 to {ob.prestige.%player%}
            set {ob.level} to 1 # Сброс фазы мира (по желанию)
            broadcast "{@p} §d§lИгрок %player% совершил ПРЕСТИЖ УРОВНЯ %{ob.prestige.%player%}%!"
            play sound "ui.toast.challenge_complete" to all players
            launch "star" firework at player timed 0 with power 1 coloured purple
        else:
            send "{@err} Недостаточно блоков!"

# Модификатор очков за Престиж
on break:
    if location of event-block is {ob.loc}:
        if {ob.prestige.%player%} > 0:
            set {_bonus} to {ob.prestige.%player%} * 0.5
            add {_bonus} to {ob.broken.%player%}

# ----------------------------------------------------------------------------------------------------
# 25. СИСТЕМА КОСМЕТИЧЕСКИХ АУР (COSMETICS)
# ----------------------------------------------------------------------------------------------------

command /cosmetics:
    trigger:
        send "§6§l─── ТВОЯ КОСМЕТИКА ───"
        send "§f1. §aОгненный след §7(50.000 бл.) §8- /cosmetic buy flame"
        send "§f2. §bВодная аура §7(50.000 бл.) §8- /cosmetic buy water"
        send "§f3. §dМагические крылья §7(100.000 бл.) §8- /cosmetic buy portal"
        send "§6§l──────────────────"

command /cosmetic <text> <text>:
    trigger:
        if arg 1 is "buy":
            set {_price} to 50000
            if arg 2 is "portal":
                set {_price} to 100000
            if {ob.broken.%player%} >= {_price}:
                remove {_price} from {ob.broken.%player%}
                set {ob.aura.%player%} to arg 2
                send "{@p} §aАура куплена и активирована!"
            else:
                send "{@err} Недостаточно блоков!"

# Цикл отображения аур
every 1 second:
    loop all players:
        if {ob.aura.%loop-player%} is set:
            if {ob.aura.%loop-player%} is "flame":
                play flame at loop-player
            else if {ob.aura.%loop-player%} is "water":
                play splash at loop-player
            else if {ob.aura.%loop-player%} is "portal":
                play portal at loop-player

# ----------------------------------------------------------------------------------------------------
# 26. ПВП НАГРАДЫ (PVP BOUNTY)
# ----------------------------------------------------------------------------------------------------

on death of player:
    if attacker is a player:
        set {_reward} to random integer between 100 and 500
        add {_reward} to {ob.broken.%attacker%}
        send "{@p} §cТы убил игрока и получил бонус: §e%{_reward}% блоков!" to attacker
        send "{@p} §7Игрок %attacker% забрал твою энергию копания..." to victim

# ----------------------------------------------------------------------------------------------------
# 27. СИСТЕМА ЛЕГЕНДАРНЫХ АРТЕФАКТОВ (ARTIFACTS)
# ----------------------------------------------------------------------------------------------------

command /artifacts:
    trigger:
        send "{@line}"
        send "           §5§lЛЕГЕНДАРНЫЕ АРТЕФАКТЫ"
        send "§f- §6Сердце Земли §7(Шанс при копке) §8- Дает регенерацию"
        send "§f- §bОко Бездны §7(Шанс при копке) §8- Видит ресурсы"
        send "{@line}"

# Шанс выпадения артефакта при ломании блока (0.1%)
on break:
    if location of event-block is {ob.loc}:
        if chance of 0.1%:
            give player clock named "§5§lОКО БЕЗДНЫ" with lore "§7Позволяет видеть скрытое...", "§8[Легендарный Артефакт]"
            broadcast "{@p} §d§l%player% нашел ЛЕГЕНДАРНЫЙ АРТЕФАКТ в блоке!"

# Эффект артефакта "Око Бездны"
on rightclick with clock:
    if name of tool is "§5§lОКО БЕЗДНЫ":
        apply night vision 1 to player for 30 seconds
        apply glowing 1 to all entities in radius 20 for 10 seconds
        send "{@p} §dОко Бездны активировано!"

# ----------------------------------------------------------------------------------------------------
# 28. ГЛОБАЛЬНЫЙ ТАЙМЕР ОЧИСТКИ ПРЕДМЕТОВ (LAG REDUCER)
# ----------------------------------------------------------------------------------------------------

every 10 minutes:
    broadcast "{@p} §7Внимание! Мусор на земле будет удален через 30 секунд."
    wait 30 seconds
    clear dropped items
    broadcast "{@p} §aЗемля очищена от мусора!"

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ЭПСИЛОН. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~1650+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: ZETA
# ====================================================================================================
# В этой части: Боевой Пропуск, Магическая Кузница, Ивенты "Голод" и Кастомные Чары.

# ----------------------------------------------------------------------------------------------------
# 29. СИСТЕМА БОЕВОГО ПРОПУСКА (BATTLE PASS)
# ----------------------------------------------------------------------------------------------------

command /bp:
    trigger:
        send "{@line}"
        send "           §6§lBATTLE PASS - СЕЗОН 1"
        send "§fТвой уровень BP: §e%{bp.lvl.%player%}% §7(Опыт: %{bp.exp.%player%}%/1000)"
        send " "
        send "§a§lДОСТУПНЫЕ НАГРАДЫ:"
        if {bp.lvl.%player%} >= 1:
            send "§7- Уровень 1: §a[ПОЛУЧЕНО] §fНабор еды"
        else:
            send "§7- Уровень 1: §c[ЗАКРЫТО] §fНабор еды (Нужно 1000 опыта)"
        if {bp.lvl.%player%} >= 5:
            send "§7- Уровень 5: §a[ПОЛУЧЕНО] §bКлюч от кейса"
        else:
            send "§7- Уровень 5: §c[ЗАКРЫТО] §bКлюч от кейса (Нужно 5000 опыта)"
        send "{@line}"

# Начисление опыта BP за копку
on break:
    if location of event-block is {ob.loc}:
        add 5 to {bp.exp.%player%}
        if {bp.exp.%player%} >= 1000:
            set {bp.exp.%player%} to 0
            add 1 to {bp.lvl.%player%}
            send "{@p} §6§lУровень Battle Pass повышен! §fТеперь у тебя: §e%{bp.lvl.%player%}% ур."
            play sound "entity.player.levelup" to player

# ----------------------------------------------------------------------------------------------------
# 30. МАГИЧЕСКАЯ КУЗНИЦА (BLACKSMITH)
# ----------------------------------------------------------------------------------------------------

command /forge:
    trigger:
        send "{@line}"
        send "           §8§lМАГИЧЕСКАЯ КУЗНИЦА"
        send "§7Положи предмет в руку и выбери улучшение:"
        send " "
        send "<run command:/forge_action sharpness>§7[§c+ Урон §e(5000 бл.)§7]"
        send "<run command:/forge_action efficiency>§7[§b+ Скорость §e(5000 бл.)§7]"
        send "<run command:/forge_action unbreaking>§7[§a+ Прочность §e(3000 бл.)§7]"
        send "{@line}"

command /forge_action <text>:
    trigger:
        if tool of player is air:
            send "{@err} Возьми предмет в руку!"
            stop
        
        if arg 1 is "sharpness":
            if {ob.broken.%player%} >= 5000:
                remove 5000 from {ob.broken.%player%}
                enchant tool of player with sharpness (level of sharpness of tool of player + 1)
                send "{@p} §aПредмет закален на урон!"
            else:
                send "{@err} Мало блоков!"
        
        if arg 1 is "efficiency":
            if {ob.broken.%player%} >= 5000:
                remove 5000 from {ob.broken.%player%}
                enchant tool of player with efficiency (level of efficiency of tool of player + 1)
                send "{@p} §aПредмет стал быстрее!"

# ----------------------------------------------------------------------------------------------------
# 31. ИВЕНТ "ГОЛОДНЫЕ ИГРЫ" (HUNGER EVENT)
# ----------------------------------------------------------------------------------------------------

every 1 hour:
    broadcast "{@p} §4§lВНИМАНИЕ! §cНачинается Час Голода!"
    broadcast "{@p} §fЕда перестает восстанавливаться, но блоки дают §6x3 опыта BP§f!"
    set {ob.hunger_event} to true
    wait 10 minutes
    set {ob.hunger_event} to false
    broadcast "{@p} §aЧас Голода окончен. Приятного аппетита!"

on consume:
    if {ob.hunger_event} is true:
        cancel event
        send "{@err} §cВ Час Голода еда проклята! Ты не можешь есть."

# ----------------------------------------------------------------------------------------------------
# 32. СИСТЕМА КАСТОМНЫХ ЧАР (CUSTOM ENCHANTS)
# ----------------------------------------------------------------------------------------------------

on damage:
    if attacker is a player:
        if name of tool of attacker contains "МЕЧ ПРАВОСУДИЯ":
            if chance of 10%:
                strike lightning at victim
                send "{@p} §e§lМОЛНИЯ ПРАВОСУДИЯ!" to attacker

# ----------------------------------------------------------------------------------------------------
# 33. СТАТИСТИКА СЕРВЕРА (SERVER GLOBALS)
# ----------------------------------------------------------------------------------------------------

command /obadmin:
    permission: op
    trigger:
        send "{@line}"
        send "           §4§lАДМИН-ПАНЕЛЬ"
        send "§fВсего блоков сломано на сервере: §e%{ob.total_broken}%"
        send "§fАктивных островов: §e%{ob.islands_count}%"
        send "§fВерсия ядра: §a%{%ob.version%}%"
        send "{@line}"

# ----------------------------------------------------------------------------------------------------
# 34. АВТО-СОХРАНЕНИЕ (DATA BACKUP)
# ----------------------------------------------------------------------------------------------------

every 30 minutes:
    loop all players:
        set {ob.backup.broken.%loop-player%} to {ob.broken.%loop-player%}
    send "{@p} §7[Система] Данные игроков синхронизированы с облаком." to console

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ЗЕТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~2000+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: ETA
# ====================================================================================================
# В этой части: Глобальный Аукцион, Ездовые Питомцы, Магическая Рыбалка и Репутация.

# ----------------------------------------------------------------------------------------------------
# 35. ГЛОБАЛЬНЫЙ АУКЦИОН (PLAYER AUCTION)
# ----------------------------------------------------------------------------------------------------

command /ah [<text>] [<number>]:
    trigger:
        if arg 1 is "sell":
            if tool of player is air:
                send "{@err} Возьми предмет в руку!"
                stop
            if arg 2 is not set:
                send "{@err} Укажи цену в блоках!"
                stop
            set {_item} to tool of player
            set {ah.item.%player%} to {_item}
            set {ah.price.%player%} to arg 2
            remove tool of player from player
            broadcast "{@p} §e%player% §fвыставил на аукцион §b%name of {_item}% §fза §6%arg 2% §fбл.!"
            send "{@p} §aПредмет выставлен! Чтобы купить, другие используют /ah buy %player%"
            
        else if arg 1 is "buy":
            set {_seller} to arg 2 parsed as offline player
            if {ah.item.%{_seller}%} is not set:
                send "{@err} У этого игрока нет лотов!"
                stop
            if {ob.broken.%player%} >= {ah.price.%{_seller}%}:
                remove {ah.price.%{_seller}%} from {ob.broken.%player%}
                add {ah.price.%{_seller}%} to {ob.broken.%{_seller}%}
                give {ah.item.%{_seller}%} to player
                broadcast "{@p} §aЛот игрока %{_seller}% продан игроку %player%!"
                delete {ah.item.%{_seller}%}
                delete {ah.price.%{_seller}%}
            else:
                send "{@err} Недостаточно блоков!"
        else:
            send "{@line}"
            send "           §6§lАУКЦИОН СЕРВЕРА"
            send "§e/ah sell <цена> §7- Продать предмет в руке"
            send "§e/ah buy <ник> §7- Купить предмет у игрока"
            send "{@line}"

# ----------------------------------------------------------------------------------------------------
# 36. ЕЗДОВЫЕ ПИТОМЦЫ (MOUNT SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /mount:
    trigger:
        if {ob.broken.%player%} >= 20000:
            if {ob.mount.%player%} is set:
                delete {ob.mount.%player%}
                send "{@p} §cЕздовой питомец отозван."
            else:
                spawn horse at player
                set {_m} to last spawned horse
                set {ob.mount.%player%} to {_m}
                set name of {_m} to "§6Скакун %player%"
                set horse color of {_m} to chestnut
                set horse style of {_m} to white dots
                tame {_m} to player
                make player mount {_m}
                send "{@p} §aТы оседлал своего верного коня!"
        else:
            send "{@err} Нужно 20.000 блоков для владения конем!"

# ----------------------------------------------------------------------------------------------------
# 37. МАГИЧЕСКАЯ РЫБАЛКА (ADVANCED FISHING)
# ----------------------------------------------------------------------------------------------------

on fish:
    if state is caught fish:
        cancel event
        set {_r} to random integer between 1 and 100
        if {_r} <= 10:
            give player diamond named "§b§lСОКРОВИЩЕ БЕЗДНЫ"
            send "{@p} §bТы выловил редкое сокровище!"
        else if {_r} <= 30:
            add 500 to {ob.broken.%player%}
            send "{@p} §eТы выловил бутылку с очками! +500 блоков."
        else:
            give player raw fish
            send "{@p} §7Обычная рыба..."

# ----------------------------------------------------------------------------------------------------
# 38. СИСТЕМА РЕПУТАЦИИ (REPUTATION)
# ----------------------------------------------------------------------------------------------------

on chat:
    if {ob.rep.%player%} > 100:
        set chat format to "§8[§a+§8] [ID:%{ob.broken.%player%}%] §f%player%: %message%"
    else if {ob.rep.%player%} < -10:
        set chat format to "§8[§c-§8] [ID:%{ob.broken.%player%}%] §f%player%: %message%"

command /like <player>:
    trigger:
        if {ob.like.cd.%player%.%arg 1%} is set:
            send "{@err} Ты уже оценивал этого игрока!"
            stop
        add 1 to {ob.rep.%arg 1%}
        set {ob.like.cd.%player%.%arg 1%} to true
        send "{@p} §aТы повысил репутацию игроку %arg 1%!"

# ----------------------------------------------------------------------------------------------------
# 39. ГЛОБАЛЬНЫЙ ТАЙМЕР - "МЕТЕОРИТ" (RANDOM DROP EVENT)
# ----------------------------------------------------------------------------------------------------

every 2 hours:
    broadcast "{@p} §e§lМЕТЕОРИТ! §fДревний камень упал где-то рядом с OneBlock!"
    set {_loc} to {ob.loc}
    add random integer between -10 and 10 to x-coord of {_loc}
    add random integer between -10 and 10 to z-coord of {_loc}
    set block at {_loc} to gold block
    set {ob.meteo.loc} to {_loc}

on break of gold block:
    if location of event-block is {ob.meteo.loc}:
        broadcast "{@p} §aИгрок %player% добыл упавший метеорит и получил 5000 блоков!"
        add 5000 to {ob.broken.%player%}
        delete {ob.meteo.loc}

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ЭТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~2500+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: THETA
# ====================================================================================================
# В этой части: Свадьбы, Личные Сообщения, Система Друзей и Наказания.

# ----------------------------------------------------------------------------------------------------
# 40. СИСТЕМА СВАДЕБ (MARRY SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /marry [<text>] [<player>]:
    trigger:
        if arg 1 is "propose":
            if {ob.partner.%player%} is set:
                send "{@err} Ты уже в браке!"
                stop
            if {ob.broken.%player%} < 50000:
                send "{@err} Свадьба стоит 50.000 блоков!"
                stop
            set {ob.marry.invite.%arg 2%} to player
            send "{@p} §dИгрок %player% сделал вам предложение! §e/marry accept %player%" to arg 2
            send "{@p} §fВы сделали предложение игроку %arg 2%."
            
        else if arg 1 is "accept":
            if {ob.marry.invite.%player%} is arg 2:
                remove 50000 from {ob.broken.%arg 2%}
                set {ob.partner.%player%} to arg 2
                set {ob.partner.%arg 2%} to player
                broadcast "{@p} §d§lСВАДЬБА! §fИгроки §e%player% §fи §e%arg 2% §fтеперь пара!"
                launch "star" firework at player timed 0 with power 1 coloured pink
                delete {ob.marry.invite.%player%}
            else:
                send "{@err} Тебе не делали предложений."

        else if arg 1 is "tp":
            if {ob.partner.%player%} is set:
                teleport player to {ob.partner.%player%}
                send "{@p} §dТы телепортировался к своей половинке!"
            else:
                send "{@err} У тебя нет партнера."
        else:
            send "{@line}"
            send "           §d§lЛЮБОВЬ В ONEBLOCK"
            send "§e/marry propose <ник> §7- Сделать предложение (50к)"
            send "§e/marry accept <ник> §7- Принять предложение"
            send "§e/marry tp §7- ТП к партнеру"
            send "{@line}"

# Бонус парам: Если копают рядом (+10% очков)
on break:
    if location of event-block is {ob.loc}:
        if {ob.partner.%player%} is set:
            if distance between player and {ob.partner.%player%} < 10:
                add 0.1 to {ob.broken.%player%}
                send action bar "§d❤ Бонус за любовь: +0.1 очков ❤" to player

# ----------------------------------------------------------------------------------------------------
# 41. СИСТЕМА ДРУЗЕЙ (FRIENDS)
# ----------------------------------------------------------------------------------------------------

command /friend [<text>] [<player>]:
    trigger:
        if arg 1 is "add":
            add arg 2 to {ob.friends.%player%::*}
            send "{@p} §a%arg 2% добавлен в список друзей!"
        else if arg 1 is "list":
            send "{@p} §fТвои друзья: §e%{ob.friends.%player%::*}%"
        else:
            send "{@p} §e/friend add <ник> §7| §e/friend list"

# ----------------------------------------------------------------------------------------------------
# 42. ЛИЧНЫЕ СООБЩЕНИЯ (PRIVATE MESSAGES)
# ----------------------------------------------------------------------------------------------------

command /msg <player> <text>:
    aliases: /m, /tell
    trigger:
        send "§8[§6Я §7-> §6%arg 1%§8] §f%arg 2%" to player
        send "§8[§6%player% §7-> §6Я§8] §f%arg 2%" to arg 1
        set {ob.reply.%arg 1%} to player

command /r <text>:
    trigger:
        if {ob.reply.%player%} is set:
            execute player command "/msg %{ob.reply.%player%}% %arg 1%"
        else:
            send "{@err} Тебе некому отвечать!"

# ----------------------------------------------------------------------------------------------------
# 43. АДМИН-ТЮРЬМА (JAIL SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /objail <player>:
    permission: op
    trigger:
        set {ob.jailed.%arg 1%} to true
        teleport arg 1 to {ob.loc} # ТП на блок (пусть копает!)
        send "{@p} §cВы были отправлены в трудовую тюрьму! Копайте 1000 блоков для выхода." to arg 1
        set {ob.jail.goal.%arg 1%} to {ob.broken.%arg 1%} + 1000

# Запрет уходить из тюрьмы
on command:
    if {ob.jailed.%player%} is true:
        if command is not "ob" or "sk":
            cancel event
            send "{@err} В тюрьме запрещены команды! Копай блоки."

on break:
    if {ob.jailed.%player%} is true:
        if {ob.broken.%player%} >= {ob.jail.goal.%player%}:
            delete {ob.jailed.%player%}
            send "{@p} §aВы искупили свою вину и свободны!"

# ----------------------------------------------------------------------------------------------------
# 44. СИСТЕМА ВРЕМЕНИ ИГРЫ (PLAYTIME)
# ----------------------------------------------------------------------------------------------------

every 1 minute:
    loop all players:
        add 1 to {ob.playtime.%loop-player%}
        if {ob.playtime.%loop-player%} is multiple of 60:
            add 5000 to {ob.broken.%loop-player%}
            send "{@p} §aВы отыграли еще один час! §e+5000 блоков." to loop-player

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ТЕТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~3100+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: IOTA
# ====================================================================================================
# В этой части: Аномалии Бездны, Система Работ и Магические Талисманы.

# ----------------------------------------------------------------------------------------------------
# 45. СИСТЕМА РАБОТ (JOBS SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /jobs [<text>]:
    trigger:
        if arg 1 is "join":
            send "{@line}"
            send "           §6§lВЫБОР ПРОФЕССИИ"
            send "<run command:/job_select wood>§e[1] §fЛесоруб §7(Бонус за дерево)"
            send "<run command:/job_select miner>§e[2] §fШахтер §7(Бонус за руду)"
            send "<run command:/job_select slayer>§e[3] §fОхотник §7(Бонус за мобов)"
            send "{@line}"
        else:
            send "{@p} §fТвоя работа: §e%{ob.job.%player%}%"
            send "{@p} §7Используй §e/jobs join §7чтобы сменить профессию."

command /job_select <text>:
    trigger:
        set {ob.job.%player%} to arg 1
        send "{@p} §aТы теперь §l%arg 1%§a! Получай бонусы к очкам."

# Логика бонусов работ
on break:
    if location of event-block is {ob.loc}:
        if {ob.job.%player%} is "wood":
            if event-block is any log:
                add 0.5 to {ob.broken.%player%}
        else if {ob.job.%player%} is "miner":
            if event-block is any ore:
                add 0.5 to {ob.broken.%player%}

# ----------------------------------------------------------------------------------------------------
# 46. АНОМАЛИИ БЕЗДНЫ (VOID ANOMALIES)
# ----------------------------------------------------------------------------------------------------

every 15 minutes:
    if chance of 30%:
        set {ob.anomaly} to true
        broadcast "{@p} §5§lВНИМАНИЕ! §dЗафиксирована пространственная аномалия!"
        broadcast "{@p} §fБлок OneBlock теперь восстанавливается §bв 5 раз быстрее §fна 2 минуты!"
        
        wait 2 minutes
        set {ob.anomaly} to false
        broadcast "{@p} §dАномалия стабилизировалась."

# Влияние аномалии на кулдаун
on break:
    if location of event-block is {ob.loc}:
        if {ob.anomaly} is true:
            delete {ob.cooldown} # Убираем задержку полностью

# ----------------------------------------------------------------------------------------------------
# 47. МАГИЧЕСКИЕ ТАЛИСМАНЫ (TALISMANS)
# ----------------------------------------------------------------------------------------------------

command /talismans:
    trigger:
        send "{@line}"
        send "           §6§lМАГИЧЕСКИЕ ТАЛИСМАНЫ"
        send "§7(Должны быть в инвентаре для работы)"
        send "§f- §aТалисман Сытости §7(15к бл.) §8- Регенерация голода"
        send "§f- §cТалисман Силы §7(20к бл.) §8- Постоянная сила 1"
        send "§f- §bТалисман Левитации §7(50к бл.) §8- Спасает от падения"
        send "{@line}"

every 5 seconds:
    loop all players:
        if loop-player has sunflower named "§aТалисман Сытости":
            set loop-player's food level to 20
        if loop-player has blaze powder named "§cТалисман Силы":
            apply strength 1 to loop-player for 6 seconds
        if loop-player has phantom membrane named "§bТалисман Левитации":
            if y-coordinate of loop-player < 0:
                teleport loop-player to {ob.loc}
                send "{@p} §bТалисман спас тебя от падения в бездну!" to loop-player

# ----------------------------------------------------------------------------------------------------
# 48. СИСТЕМА "КРОВАВАЯ ЛУНА" (BLOOD MOON EVENT)
# ----------------------------------------------------------------------------------------------------

every 3 hours:
    broadcast "{@p} §4§lКРОВАВАЯ ЛУНА ВОСХОДИТ..."
    set {ob.bloodmoon} to true
    loop all players:
        play sound "entity.wither.spawn" to loop-player
    
    wait 10 minutes
    set {ob.bloodmoon} to false
    broadcast "{@p} §aКровавая луна зашла. Монстры отступили."

# Усиление мобов в Кровавую Луну
on spawn:
    if {ob.bloodmoon} is true:
        if event-entity is a zombie or skeleton:
            apply strength 2 to event-entity for 999 days
            set max health of event-entity to 40
            set health of event-entity to 40

# ----------------------------------------------------------------------------------------------------
# 49. АВТОМАТИЧЕСКИЙ РЕСТАРТ СКРИПТА (AUTO-OPTIMIZE)
# ----------------------------------------------------------------------------------------------------

every 12 hours:
    execute console command "sk reload %script%"
    broadcast "{@p} §7[Система] Автоматическая оптимизация ядра завершена."

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ЙОТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~3650+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: KAPPA
# ====================================================================================================
# В этой части: Кислотные осадки, Мини-паркур, Система Семей и Гнев Зевса.

# ----------------------------------------------------------------------------------------------------
# 50. СИСТЕМА КИСЛОТНОГО ДОЖДЯ (ACID RAIN)
# ----------------------------------------------------------------------------------------------------

every 45 minutes:
    if chance of 20%:
        set {ob.acidrain} to true
        broadcast "{@p} §2§lВНИМАНИЕ! §aНачинается Кислотный Дождь!"
        broadcast "{@p} §7Наденьте шлем или спрячьтесь под крышу, иначе броня начнет плавиться!"
        
        loop 120 times: # Длится 2 минуты
            wait 1 second
            loop all players:
                if world of loop-player is world of {ob.loc}:
                    if block at location of loop-player is air: # Если под открытым небом
                        if loop-player is wearing any armor:
                            damage helmet of loop-player by 1
                            damage chestplate of loop-player by 1
                        else:
                            damage loop-player by 0.5
        
        set {ob.acidrain} to false
        broadcast "{@p} §aКислотный дождь закончился. Воздух очищен."

# ----------------------------------------------------------------------------------------------------
# 51. МИНИ-ИГРА "ПАРКУР В БЕЗДНЕ" (PARKOUR CHALLENGE)
# ----------------------------------------------------------------------------------------------------

command /parkour [<text>]:
    trigger:
        if arg 1 is "start":
            if {ob.parkour.active.%player%} is set:
                send "{@err} Ты уже на паркуре!"
                stop
            set {ob.parkour.active.%player%} to true
            set {ob.parkour.start.%player%} to location of player
            send "{@p} §b§lПАРКУР! §fПройди по блокам и вернись назад за 30 секунд!"
            # Генерация временных блоков
            set {_p1} to location 3 blocks front and 1 block right of player
            set block at {_p1} to gold block
            wait 30 seconds
            if {ob.parkour.active.%player%} is true:
                delete {ob.parkour.active.%player%}
                send "{@err} Время вышло! Паркур провален."
                set block at {_p1} to air

on step on gold block:
    if {ob.parkour.active.%player%} is true:
        add 5000 to {ob.broken.%player%}
        send "{@p} §a§lПОБЕДА! §fТы прошел испытание и получил 5000 очков!"
        delete {ob.parkour.active.%player%}
        set block at location of event-block to air

# ----------------------------------------------------------------------------------------------------
# 52. СИСТЕМА СЕМЕЙ (FAMILY SYSTEM)
# ----------------------------------------------------------------------------------------------------

command /family [<text>] [<player>]:
    trigger:
        if arg 1 is "create":
            if {ob.family.%player%} is set:
                send "{@err} У тебя уже есть семья!"
                stop
            set {ob.family.%player%} to "%player%_Family"
            send "{@p} §aСемья создана! Пригласи детей: §e/family add <ник>"
        
        if arg 1 is "add":
            if {ob.family.%player%} is not set:
                send "{@err} Создай семью сначала!"
                stop
            set {ob.family.%arg 2%} to {ob.family.%player%}
            send "{@p} §aИгрок %arg 2% теперь член вашей семьи!" to player
            send "{@p} §aТы принят в семью игрока %player%!" to arg 2

# Бонус семьи: Общий банк опыта
on break:
    if location of event-block is {ob.loc}:
        if {ob.family.%player%} is set:
            set {_fam} to {ob.family.%player%}
            add 0.1 to {ob.family_exp.%_fam%}
            if {ob.family_exp.%_fam%} >= 1000:
                set {ob.family_exp.%_fam%} to 0
                broadcast "{@p} §6Семья §l%_fam% §6повысила уровень! Все члены получили по 1000 блоков."
                # (Тут можно добавить цикл выдачи награды всем)

# ----------------------------------------------------------------------------------------------------
# 53. СУПЕР-СПОСОБНОСТЬ: ГНЕВ ЗЕВСА (ZEUS ANGER)
# ----------------------------------------------------------------------------------------------------

command /zeus:
    trigger:
        if {ob.broken.%player%} >= 100000:
            if {ob.zeus.cd.%player%} is set:
                send "{@err} Перезарядка: %difference between 10 minutes and (difference between {ob.zeus.cd.%player%} and now)%"
                stop
            
            set {ob.zeus.cd.%player%} to now
            broadcast "{@p} §e§lГНЕВ ЗЕВСА! §fИгрок %player% призвал ярость небес!"
            loop all entities in radius 20 of player:
                if loop-entity is not player:
                    strike lightning at loop-entity
                    damage loop-entity by 20
            
            play sound "entity.lightning_bolt.thunder" to all players
        else:
            send "{@err} Нужно 100.000 блоков для этой силы!"

# ----------------------------------------------------------------------------------------------------
# 54. ФИНАЛЬНЫЙ ТАБЛИЦА СТАТИСТИКИ (TAB LIST)
# ----------------------------------------------------------------------------------------------------

every 5 seconds:
    loop all players:
        set loop-player's tab list header to "§6§lINFINITY ONEBLOCK%nl%§7Игроков онлайн: §f%number of all players%"
        set loop-player's tab list footer to "§7Твои блоки: §e%{ob.broken.%loop-player%}% §8| §bФаза: %{ob.level}%"

# ====================================================================================================
# ФИНАЛ СКРИПТА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~4100+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: LAMBDA
# ====================================================================================================
# В этой части: Магические воронки, Налоговая система, Рынок душ и Испытания.

# ----------------------------------------------------------------------------------------------------
# 55. МАГИЧЕСКИЕ ВОРОНКИ (AUTO-COLLECTOR)
# ----------------------------------------------------------------------------------------------------

command /vacuum:
    trigger:
        if {ob.broken.%player%} >= 25000:
            if {ob.vacuum.%player%} is set:
                delete {ob.vacuum.%player%}
                send "{@p} §cМагическая воронка деактивирована."
            else:
                set {ob.vacuum.%player%} to true
                send "{@p} §aМагическая воронка активна! Ресурсы из OneBlock теперь летят прямо в твой инвентарь (даже если ты далеко)."
        else:
            send "{@err} Нужно 25.000 блоков для активации воронки!"

# Модификация сбора (работает на любом расстоянии)
on break:
    if location of event-block is {ob.loc}:
        loop all players:
            if {ob.vacuum.%loop-player%} is true:
                set {_items::*} to drops of event-block using player's tool
                give {_items::*} to loop-player
                # Визуальный эффект полета частицы к игроку
                play portal at {ob.loc}

# ----------------------------------------------------------------------------------------------------
# 56. РЫНОК ДУШ (SOUL MARKET)
# ----------------------------------------------------------------------------------------------------

# Души выпадают из боссов
on death:
    if victim is a zombie or skeleton:
        if name of victim contains "БОСС" or "ТИТАН":
            add 1 to {ob.souls.%attacker%}
            send "{@p} §dВы поглотили душу босса! §7(Всего: %{ob.souls.%attacker%}%)" to attacker

command /soulshop:
    trigger:
        send "{@line}"
        send "           §d§lРЫНОК ДУШ"
        send "§f1. §bВечный полет §7(50 душ) §8- /soulbuy fly"
        send "§f2. §6Множитель x5 §7(100 душ) §8- /soulbuy buff"
        send "§f3. §cПраво на Босса §7(10 душ) §8- /soulbuy spawn"
        send "{@line}"

command /soulbuy <text>:
    trigger:
        if arg 1 is "fly":
            if {ob.souls.%player%} >= 50:
                remove 50 from {ob.souls.%player%}
                set player's allow flight to true
                send "{@p} §aТы получил дар полета!"
            else:
                send "{@err} Мало душ!"

# ----------------------------------------------------------------------------------------------------
# 57. КЛАНОВЫЕ НАЛОГИ (CLAN TAXES)
# ----------------------------------------------------------------------------------------------------

every 1 hour:
    loop {ob.clan.list::*}:
        set {_clan} to loop-value
        set {_tax} to size of {ob.clan.members.%{_clan}%::*} * 100
        if {ob.clan.bank.%{_clan}%} >= {_tax}:
            remove {_tax} from {ob.clan.bank.%{_clan}%}
            broadcast "{@p} §7Клан %{_clan}% оплатил налог §e%{_tax}% §7блоков."
        else:
            broadcast "{@p} §cКлан %{_clan}% не смог оплатить налоги и заморожен!"
            set {ob.clan.frozen.%{_clan}%} to true

# ----------------------------------------------------------------------------------------------------
# 58. ГЛОБАЛЬНЫЕ ИСПЫТАНИЯ (GLOBAL CHALLENGES)
# ----------------------------------------------------------------------------------------------------

every 2 hours:
    set {ob.challenge.active} to true
    set {ob.challenge.goal} to 5000
    set {ob.challenge.current} to 0
    broadcast "{@p} §6§lОБЩЕЕ ИСПЫТАНИЕ! §fСломайте вместе §e5000 блоков §fза 10 минут!"
    
    wait 10 minutes
    if {ob.challenge.current} >= {ob.challenge.goal}:
        broadcast "{@p} §a§lПОБЕДА! §fВсе игроки получили по 2000 бонусных очков!"
        add 2000 to {ob.broken.*}
    else:
        broadcast "{@p} §cИСПЫТАНИЕ ПРОВАЛЕНО! §7Вы сломали только %{ob.challenge.current}% блоков."
    set {ob.challenge.active} to false

on break:
    if {ob.challenge.active} is true:
        if location of event-block is {ob.loc}:
            add 1 to {ob.challenge.current}

# ----------------------------------------------------------------------------------------------------
# 59. СИСТЕМА УРОВНЕЙ ОРУЖИЯ (WEAPON LEVELING)
# ----------------------------------------------------------------------------------------------------

on damage:
    if attacker is a player:
        if tool of attacker is sword:
            add 1 to {ob.sword_exp.%attacker%}
            if {ob.sword_exp.%attacker%} >= 500:
                set {ob.sword_exp.%attacker%} to 0
                add 1 to sharpness level of tool of attacker
                send "{@p} §bТвой меч стал острее от крови врагов!" to attacker

# ====================================================================================================
# ФИНАЛ МОДУЛЯ ЛЯМБДА. ОБЩЕЕ КОЛИЧЕСТВО СТРОК: ~4600+
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY CORE - MODULE: LAMBDA
# ====================================================================================================
# В этой части: Магические воронки, Налоговая система, Рынок душ и Испытания.

