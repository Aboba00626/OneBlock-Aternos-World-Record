        set {ob.genesis.energy} to true
        broadcast "{@p} §0§lЭНЕРГИЯ ГЕНЕЗИСА §fпропитывает мир..."
        loop all players:
            apply speed 2 to loop-player for 60 seconds
            play dragon breath at loop-player

