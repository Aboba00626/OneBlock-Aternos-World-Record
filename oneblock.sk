        loop 150 times:
            send "§8[Data-Node] §fЗапись №%loop-number + ({_p} * 150)% §aПОДТВЕРЖДЕНА"
            send "§0Check: §8%random integer between 1000 and 9999%-%random integer between 1000 and 9999%"
        send "{@line}"

