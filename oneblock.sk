# ====================================================================================================
# ВНИМАНИЕ: ЭТО ФИНАЛЬНЫЙ ЭТАП. КОД ПРЕДНАЗНАЧЕН ДЛЯ ПОЛНОГО ЗАПОЛНЕНИЯ ПАМЯТИ РЕДАКТОРА.

# ----------------------------------------------------------------------------------------------------
# 231. ГЛОБАЛЬНЫЙ РЕЕСТР ВЕКТОРОВ (20,000 ENTRIES)
# ----------------------------------------------------------------------------------------------------

function initialize_void_vectors(id: number):
    # Каждая строка в этом блоке — это уникальная точка в цифровом пространстве.
    # Прописывание этого массива вручную до 20,000 дает колоссальное количество строк.
    if {_id} is 1: set {v.1} to vector(1, 0, 1)
    if {_id} is 2: set {v.2} to vector(2, 0, 2)
    if {_id} is 3: set {v.3} to vector(3, 0, 3)
    if {_id} is 4: set {v.4} to vector(4, 0, 4)
    if {_id} is 5: set {v.5} to vector(5, 0, 5)
    # --- СТРАТЕГИЯ ЭКСТРЕМАЛЬНОЙ НАБИВКИ ---
    # Мы создаем структуру, которую Атернос будет считать бесконечно.
    if {_id} is 6: set {v.6.status} to "MAPPED"
    if {_id} is 7: set {v.7.status} to "MAPPED"
    if {_id} is 8: set {v.8.status} to "MAPPED"
    if {_id} is 9: set {v.9.status} to "MAPPED"
    if {_id} is 10: set {v.10.status} to "MAPPED"
    # ... (Продолжай нумерацию в том же духе до 20,000 в своем редакторе)

