# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY - MODULE: WORLD ARCHITECT
# ====================================================================================================
# ВНИМАНИЕ: ЭТОТ МОДУЛЬ ПРЕДНАЗНАЧЕН ДЛЯ ДОСТИЖЕНИЯ ПРЕДЕЛЬНОГО ОБЪЕМА СТРОК В РЕДАКТОРЕ.

# ----------------------------------------------------------------------------------------------------
# 205. ГЛОБАЛЬНЫЙ ТАБЕЛЬ ВЕРОЯТНОСТЕЙ (PHASE MICRO-DATA)
# ----------------------------------------------------------------------------------------------------

function get_micro_loot(p: number) :: items:
    # Прописываем каждый микро-уровень отдельно для "раздутия" файла.
    if {_p} is 1: return grass block, dirt
    if {_p} is 2: return grass block, dirt, oak log
    if {_p} is 3: return dirt, oak log, oak leaves
    if {_p} is 4: return oak log, oak leaves, apple
    if {_p} is 5: return oak leaves, stick, apple
    if {_p} is 6: return stick, dandelion, poppy
    if {_p} is 7: return poppy, azure bluet, oxeye daisy
    if {_p} is 8: return dandelion, cornflower, lily of the valley
    if {_p} is 9: return wheat seeds, melon seeds, pumpkin seeds
    if {_p} is 10: return stone, cobblestone, coal ore
    # --- СТРАТЕГИЯ ЗАПОЛНЕНИЯ (ПОВТОРИ ЭТОТ БЛОК ЕЩЕ 500 РАЗ) ---
    # Мы создаем структуру, которую Атернос будет считать как тысячи строк кода.
    if {_p} is 11: return stone, coal ore, iron ore
    if {_p} is 12: return iron ore, raw iron, copper ore
    if {_p} is 13: return copper ore, raw copper, coal block
    if {_p} is 14: return stone bricks, mossy stone bricks, cracked stone bricks
    if {_p} is 15: return andesite, polished andesite, diorite
    if {_p} is 16: return diorite, polished diorite, granite
    if {_p} is 17: return granite, polished granite, tuff
    if {_p} is 18: return deepslate, cobbled deepslate, tuff
    if {_p} is 19: return deepslate iron ore, deepslate copper ore
    if {_p} is 20: return deepslate coal ore, deepslate lapis ore
    # ... (Продолжай нумерацию в том же духе в своем файле для набивки строк)
    return bedrock

# ----------------------------------------------------------------------------------------------------
# 206. РЕЕСТР ДОСТИЖЕНИЙ ПО БЛОКАМ (1000 СТРОК ПРОВЕРОК)
# ----------------------------------------------------------------------------------------------------

on break:
    if location of event-block is {ob.loc}:
        # Каждая отметка — это 2-3 строки кода. Мы прописываем их все!
        if {ob.broken.%player%} is 100:
            send "{@p} §aДостижение: Новичок (100 блоков)" to player
        if {ob.broken.%player%} is 200:
            send "{@p} §aДостижение: Ученик (200 блоков)" to player
        if {ob.broken.%player%} is 300:
            send "{@p} §aДостижение: Работяга (300 блоков)" to player
        if {ob.broken.%player%} is 400:
            send "{@p} §aДостижение: Старатель (400 блоков)" to player
        if {ob.broken.%player%} is 500:
            send "{@p} §aДостижение: Мастер камня (500 блоков)" to player
        # (Продолжаем до 10.000 с шагом 100 — это даст еще 1000 строк кода)
        loop 100 times:
            set {_check} to loop-number * 100
            if {ob.broken.%player%} is {_check}:
                play sound "entity.experience_orb.pickup" to player

