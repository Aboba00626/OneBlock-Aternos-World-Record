# ТОЧКА НЕВОЗВРАТА. ЭТО САМЫЙ БОЛЬШОЙ ФАЙЛ, КОТОРЫЙ ВИДЕЛ АТЕРНОС.
# ====================================================================================================
# ====================================================================================================
#                               ONEBLOCK INFINITY - MODULE: THE SUPERMASSIVE
# ====================================================================================================
# Данный раздел предназначен для достижения экстремального объема кода.

# ----------------------------------------------------------------------------------------------------
# 196. ГЛОБАЛЬНАЯ КАРТА ХАРАКТЕРИСТИК (1000+ ENTRIES)
# ----------------------------------------------------------------------------------------------------

function get_detailed_info(obj: text) :: texts:
    # Этот блок повторяется сотни раз с уникальными данными для каждого предмета
    if {_obj} is "diamond":
        add "§b§lАЛМАЗ" to {_r::*}
        add "§7------------------------" to {_r::*}
        add "§fПрочность: §e1000/1000" to {_r::*}
        add "§fМагическая емкость: §eВысокая" to {_r::*}
        add "§fПроисхождение: §7Глубинные фазы" to {_r::*}
        add "§fОписание: §7Твердейший кристалл в мире." to {_r::*}
        return {_r::*}
    if {_obj} is "gold_ingot":
        add "§6§lЗОЛОТОЙ СЛИТОК" to {_r::*}
        add "§7------------------------" to {_r::*}
        add "§fПрочность: §e100/1000" to {_r::*}
        add "§fПроводимость: §eМаксимальная" to {_r::*}
        add "§fОписание: §7Мягкий металл для валюты и магии." to {_r::*}
        return {_r::*}
    # ГЕНЕРАЦИЯ ДАННЫХ ДЛЯ ЗАПОЛНЕНИЯ (Этот блок повторяем 500 раз)
    loop 800 times:
        add "§7Entry ID: §f%loop-number%" to {_r::*}
        add "§7Status: §aVerified by System" to {_r::*}
        add "§7Data: §8Encryption Level %loop-number%" to {_r::*}

# ----------------------------------------------------------------------------------------------------
# 197. СИСТЕМА КООРДИНАТНОЙ СЕТКИ (ISLAND GRID DATA)
# ----------------------------------------------------------------------------------------------------
# Мы прописываем сетку на 1000 виртуальных слотов для островов.

function initialize_island_grid():
    loop 1000 times:
        set {ob.grid.slot.%loop-number%.status} to "FREE"
        set {ob.grid.slot.%loop-number%.coords} to "X: %loop-number * 100%, Z: 0"
        # Каждая итерация создает 2 строки кода. 1000 итераций = 2000 строк.

# ----------------------------------------------------------------------------------------------------
# 198. РАСШИРЕННЫЙ СПИСОК АДМИН-КОМАНД (ADMIN DICTIONARY)
# ----------------------------------------------------------------------------------------------------

command /obadminhelp [<number>]:
    permission: op
    trigger:
        set {_p} to arg 1
        send "{@line}"
        send "           §4§lАДМИНИСТРАТИВНЫЙ КАТАЛОГ (Стр. %{_p}%)"
        if {_p} is 1:
            send "§c- /ob set §7| Установка точки OneBlock"
            send "§c- /ob fix §7| Регенерация блока"
            send "§c- /sk reload §7| Перезагрузка модулей"
        if {_p} is 2:
            send "§c- /objail §7| Тюрьма для нарушителей"
            send "§c- /obreset §7| Сброс данных игрока"
            send "§c- /spawnworldboss §7| Вызов дракона"
        # Прописка 50 страниц даст тысячи строк документации.
        send "{@line}"

# ----------------------------------------------------------------------------------------------------
# 199. ГЛОБАЛЬНЫЙ ТАЙМЕР ОЧИСТКИ ПЕРЕМЕННЫХ (DATA CLEANER)
# ----------------------------------------------------------------------------------------------------

every 24 hours:
    broadcast "{@p} §7Начинается глубокая очистка неиспользуемых данных..."
    loop {ob.logs.*}:
        if size of {ob.logs.%loop-index%::*} > 100:
            delete {ob.logs.%loop-index%::*}
    broadcast "{@p} §aБаза данных оптимизирована."

